# AgendaPro - variáveis públicas do front-end
# Configure também na Vercel > Project > Settings > Environment Variables

VITE_SUPABASE_URL=https://jssymlzkdrnsftnnsbbo.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
VITE_SUPABASE_ANON_KEY=your_publishable_key_here

# Mercado Pago - links públicos de pagamento
VITE_MERCADO_PAGO_ESSENTIAL_LINK=https://mpago.la/2aynw39
VITE_MERCADO_PAGO_PROFESSIONAL_LINK=https://mpago.la/1D2cMK7
VITE_MERCADO_PAGO_BUSINESS_LINK=https://mpago.la/1ZJRTao
VITE_MERCADO_PAGO_IMPLEMENTATION_LINK=https://mpago.la/17N4Eme

# Mercado Pago - API/webhook automático, somente backend/Vercel, nunca GitHub
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=
VITE_MERCADO_PAGO_PUBLIC_KEY=

# Supabase service role - somente backend/Vercel, nunca GitHub
SUPABASE_SERVICE_ROLE_KEY=

VITE_APP_URL=https://agenda-pro-eta.vercel.app
APP_URL=https://agenda-pro-eta.vercel.app

# Demo separada do ambiente principal
VITE_AGENDAPRO_DEMO_URL=https://agendapro-demo.vercel.app/
VITE_AGENDAPRO_DEFAULT_COMPANY_SLUG=minha-agenda

DEV_ADMIN_EMAIL=
DEV_ADMIN_PASSWORD=
DEV_ADMIN_SECRET=
# Segurança de sessão do cliente - backend/Vercel
# Use uma string forte, diferente da DEV_ADMIN_SECRET.
CLIENT_SESSION_SECRET=

# Resend - envio opcional de e-mails transacionais de agendamento
# Somente backend/Vercel. Se ausente, o sistema mantém copiar/WhatsApp e mostra fallback elegante.
RESEND_API_KEY=
RESEND_EMAIL_FROM=AgendaPro <contato@seudominio.com>


# =========================================================
# Testes E2E Playwright - não preencher com dados reais aqui
# Crie .env.test local fora do versionamento
# =========================================================
TEST_BASE_URL=
TEST_ADMIN_EMAIL=
TEST_ADMIN_PASSWORD=
TEST_CLIENT_ACTIVE_EMAIL=
TEST_CLIENT_ACTIVE_PASSWORD=
TEST_CLIENT_PENDING_EMAIL=
TEST_CLIENT_PENDING_PASSWORD=
TEST_CLIENT_EXPIRED_EMAIL=
TEST_CLIENT_EXPIRED_PASSWORD=
TEST_CLIENT_A_EMAIL=
TEST_CLIENT_A_PASSWORD=
TEST_CLIENT_A_AGENDA_SLUG=
TEST_CLIENT_B_EMAIL=
TEST_CLIENT_B_PASSWORD=
TEST_CLIENT_B_AGENDA_SLUG=
TEST_NORMAL_USER_EMAIL=
TEST_NORMAL_USER_PASSWORD=
TEST_NEW_USER_EMAIL_PREFIX=agenda.e2e
TEST_NEW_USER_PASSWORD=
TEST_PAYMENT_MODE=manual
TEST_MP_LINK_ESSENCIAL=https://mpago.la/2aynw39
TEST_MP_LINK_PROFISSIONAL=https://mpago.la/1D2cMK7
TEST_MP_LINK_EMPRESA=https://mpago.la/1ZJRTao
TEST_MP_LINK_IMPLANTACAO=https://mpago.la/17N4Eme
PLAYWRIGHT_SKIP_WEB_SERVER=


# Bootstrap legado: deixe false/ausente em produção.
# Ative apenas se quiser carregar uma empresa padrão direto do Supabase pelo frontend.
VITE_AGENDAPRO_ENABLE_REMOTE_BOOTSTRAP=false
VITE_AGENDAPRO_DEFAULT_COMPANY_SLUG=minha-agenda
